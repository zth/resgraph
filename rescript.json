{
  "name": "resgraph",
  "version": "0.13.2",
  "uncurried": true,
  "sources": [
    {
      "dir": "cli",
      "subdirs": true,
      "dev": true
    },
    {
      "dir": "src/res",
      "subdirs": true
    }
  ],
  "package-specs": [
    {
      "module": "esmodule",
      "in-source": true
    }
  ],
  "suffix": ".mjs",
  "dependencies": ["rescript-nodejs", "@glennsl/rescript-fetch"],
  "compiler-flags": ["-open NodeJs"]
}
