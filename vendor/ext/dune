(library
 (name ext)
 (wrapped false)
 (preprocess
  (action
   (run %{bin:cppo} %{env:CPPO_FLAGS=} %{input-file})))
 (flags
 (:standard -w +a-4-42-40-9-48-70))
 (foreign_stubs
  (language c)
  (names ext_basic_hash_stubs)))

(rule
 (targets set_ident.ml)
 (deps set.cppo.ml)
 (action
  (run %{bin:cppo} -D TYPE_IDENT %{deps} -o %{targets})))

